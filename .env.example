## AWS S3 Setup Required
# Create IAM user with:
# - AmazonS3FullAccess (or custom policy with s3:PutObject, s3:GetObject, s3:DeleteObject)
# - Attach to bucket 'lms-aja' (create if missing)

AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here  
AWS_REGION=ap-south-1
AWS_S3_BUCKET=lms-aja

# Other LMS vars (if missing)
JWT_SECRET=your_jwt_secret
PORT=5001
CORS=*

